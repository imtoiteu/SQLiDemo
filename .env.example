# SQLiLab — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Flask secret key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-secrets-token-hex-32

# SQLite database file path (relative to project root)
DATABASE_PATH=sqlilab.db

# Admin credentials — seeded on first startup
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@sqlilab.local
ADMIN_PASSWORD=Admin@SQLiLab2024!

# Optional: Flask debug mode (never True in production)
DEBUG=false
